# Example environment variables - Copy this file to .env.development or .env.production
# and fill in the appropriate values

# Client-side variables (accessible in browser)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side variables (not exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Temporary backward compatibility - will be removed in future
# Keep this in sync with SUPABASE_SERVICE_ROLE_KEY above
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
